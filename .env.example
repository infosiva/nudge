# ── AI fallback chain: Groq → Gemini → Cerebras → Anthropic ──────────────────
# Add _1, _2 suffixes for multi-key rotation (auto-switches on quota exhaustion)

GROQ_API_KEY=gsk_...           # free — console.groq.com
GROQ_API_KEY_1=gsk_...         # optional extra key
GROQ_API_KEY_2=gsk_...         # optional extra key

GEMINI_API_KEY=AIza...         # free — aistudio.google.com
GEMINI_API_KEY_1=AIza...       # optional extra key

CEREBRAS_API_KEY=csk_...       # free — cloud.cerebras.ai

ANTHROPIC_API_KEY=sk-ant-...   # paid, last resort

# ── Supabase (marketplace mode only) ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Stripe (marketplace mode only) ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.com
